# Microsoft Entra app registration (public client) used to sign in the user.
# The app must have the delegated permission: WorkIQAgent.Ask
#   (scope: api://workiq.svc.cloud.microsoft/WorkIQAgent.Ask)
# and "Allow public client flows" must be enabled for device-code flow.

# Directory (tenant) ID — or use "common"/"organizations" for multi-tenant.
TENANT_ID=your-tenant-id-here

# Application (client) ID of your Entra app registration.
CLIENT_ID=your-app-client-id-here

# Use the beta endpoint (true) or the production endpoint (false).
USE_BETA=false

# IANA time zone sent as locationHint with each message.
TIME_ZONE=America/New_York

# (Optional) Override the Work IQ MCP endpoint used by the Agent demo (Demo 2).
# Defaults to https://workiq.svc.cloud.microsoft/mcp
# WORK_IQ_MCP_ENDPOINT=https://workiq.svc.cloud.microsoft/mcp

# ---------------------------------------------------------------------------
# Demo 2 (agent) — LLM "brain" used by the LangChain agent.
# AGENT_PROVIDER: foundry | azure | openai | github
AGENT_PROVIDER=foundry

# Microsoft Foundry (AGENT_PROVIDER=foundry) — OpenAI-compatible /openai/v1
# endpoint + API key. Copy the endpoint and key from the Foundry model's
# "Call model" panel. Use the /openai/v1 base URL (NOT /responses).
FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1
FOUNDRY_DEPLOYMENT=gpt-4o
FOUNDRY_API_KEY=your-foundry-api-key

# Azure OpenAI (AGENT_PROVIDER=azure)
# AZURE_OPENAI_API_KEY=your-azure-openai-key
# AZURE_OPENAI_API_INSTANCE_NAME=your-resource-name
# AZURE_OPENAI_API_DEPLOYMENT_NAME=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-10-21

# OpenAI (AGENT_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# AGENT_MODEL=gpt-4o-mini

# GitHub Models (AGENT_PROVIDER=github)
# GITHUB_TOKEN=ghp_...
# AGENT_MODEL=gpt-4o-mini
