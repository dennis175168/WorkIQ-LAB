# Microsoft Entra app registration (public client) used to sign in the user.
# The app must have the delegated permission: WorkIQAgent.Ask
#   (scope: api://workiq.svc.cloud.microsoft/WorkIQAgent.Ask)
# and "Allow public client flows" must be enabled for device-code flow.

# Directory (tenant) ID — or use "common"/"organizations" for multi-tenant.
TENANT_ID=your-tenant-id-here

# Application (client) ID of your Entra app registration.
CLIENT_ID=your-app-client-id-here

# Use the beta endpoint (true) or the production endpoint (false).
USE_BETA=false

# IANA time zone sent as locationHint with each message.
TIME_ZONE=America/New_York
